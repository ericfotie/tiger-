generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(uuid())
  title       String
  client      String
  type        String
  description String
  images      String[]
  stars       Int      @default(0)
  date        DateTime @default(now())
}

model Message {
  id       String   @id @default(uuid())
  name     String
  subject  String
  content  String
  status   String   @default("nouveau")
  date     DateTime @default(now())
  whatsapp String
}